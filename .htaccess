<IfModule mod_rewrite.c>
    RewriteEngine On

    # API / Laravel
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    RewriteRule ^up$ index.php [L]
    RewriteRule ^api(/|$) index.php [L]

    # Yüklenen dosyalar (storage:link alternatifi)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^storage/(.*)$ backend/storage/app/public/$1 [L]

    # Kaynak klasörlerine doğrudan erişimi kapat
    RewriteRule ^(?:backend|frontend)(/|$) - [F,L]

    # Mevcut dosya ve klasörler
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # React SPA
    RewriteRule ^ index.html [L]
</IfModule>

DirectoryIndex index.html index.php

<IfModule mod_mime.c>
    AddType application/javascript js mjs
    AddType text/css css
    AddType image/svg+xml svg svgz
    AddType image/jpeg jpeg jpg jpe
    AddType image/png png
    AddType image/webp webp
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    RewriteRule ^up$ index.php [L]
    RewriteRule ^api/ index.php [L]
    RewriteRule ^migrate\.php$ - [L]

    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} !-f
    RewriteRule ^storage/(.*)$ backend/storage/app/public/$1 [L]

    RewriteRule ^(?:backend|frontend)(/|$) - [F,L]

    # Build çıktıları — var olan dosyayı doğrudan sun
    RewriteRule ^assets/ - [L]
    RewriteRule ^(favicon\.svg|apple-touch-icon\.svg)$ - [L]

    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
    RewriteRule ^ - [L]

    # Eksik JS/CSS dosyası için index.html dönme (MIME hatasını önler)
    RewriteCond %{REQUEST_URI} !^/api/ [NC]
    RewriteCond %{REQUEST_URI} \.(?:js|mjs|css|map|png|jpe?g|gif|svg|webp|ico|woff2?|ttf|eot)$ [NC]
    RewriteRule ^ - [R=404,L]

    RewriteRule ^ index.html [L]
</IfModule>

DirectoryIndex index.html index.php

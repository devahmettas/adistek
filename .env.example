# Backend
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=adistek
DB_USERNAME=root
DB_PASSWORD=

# Frontend (local geliştirme — frontend/.env dosyasına kopyalayın)
# Vite dev server ile /api proxy kullanın (subdomain ile aynı desen).
VITE_API_BASE_URL=/api

# Sunucu / subdomain yayını için frontend/.env.production zaten /api kullanır.
# backend/.env içinde APP_URL=https://subdomain.siteniz.com olmalı.
